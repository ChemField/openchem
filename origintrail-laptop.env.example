ORIGINTRAIL_GATEWAY_HOST=127.0.0.1
ORIGINTRAIL_GATEWAY_PORT=8788
ORIGINTRAIL_PUBLIC_PROXY=https://www.5mart.ml/Slag/origintrail-gateway.php

# Public wallet address is safe to expose in status output.
ORIGINTRAIL_OPERATIONAL_WALLET_ADDRESS=

# Keep this only on the laptop. Never commit or upload it to 5mart.
ORIGINTRAIL_OPERATIONAL_PRIVATE_KEY=

# Set this when publishing through a live OriginTrail node or DKG gateway.
ORIGINTRAIL_NODE_ENDPOINT=

CHEMFIELD_DATA_PATH=data/chemfield-compositions.json
CHEMFIELD_DATA_URL=https://www.5mart.ml/Slag/chemfield-compositions.json

# Reward calculator assumptions. Leave prices empty to let the gateway try CoinGecko.
ORIGINTRAIL_REWARD_STAKE_TRAC=50000
ORIGINTRAIL_REWARD_PRICE_EUR=
ORIGINTRAIL_REWARD_PRICE_USD=
ORIGINTRAIL_REWARD_VPS_COSTS_EUR=40,60,100
